# Defines environment variables and XDG Base Directories

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

# Pivot zsh configurations into XDG_CONFIG_HOME
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

# Per-tool XDG redirections
export LESSHISTFILE="$XDG_STATE_HOME/less/history"
export NODE_REPL_HISTORY="$XDG_STATE_HOME/node_repl_history"
export WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"
export INPUTRC="$XDG_CONFIG_HOME/readline/inputrc"
export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/ripgrep/config"

if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "$ZDOTDIR/.zprofile" ]]; then
  source "$ZDOTDIR/.zprofile"
fi

if [ -e $HOME/.cargo/env ]; then
  . "$HOME/.cargo/env"
fi

# rtk (Rust Token Killer) — installed under ~/.headroom/bin, not mise-managed.
# Must live here (not zshrc) so it's on PATH for non-interactive shells too,
# since Claude Code hooks invoke commands non-interactively.
RTK_HOME="$HOME/.headroom/bin"
case ":$PATH:" in
  *":$RTK_HOME:"*) ;;
  *) export PATH="$RTK_HOME:$PATH" ;;
esac
