#! /usr/bin/env zsh
# -*- mode: zsh; coding: utf-8 -*-
#
# ~/.zshrc — vios-fish

# ==============================================================================
# 0. Powerlevel10k Instant Prompt
# ==============================================================================
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ==============================================================================
# 1. Environment Variables & Path Configuration
# ==============================================================================
export LANG=ja_JP.UTF-8
export LC_ALL=ja_JP.UTF-8

# Ensure path arrays do not contain duplicates.
typeset -U path fpath manpath infopath

# Base Paths (Priority from top to bottom)
path=(
  $HOME/.local/bin
  $HOME/local/bin
  $HOME/.cargo/bin
  $HOME/go/bin
  /usr/local/sbin
  /usr/local/bin
  /usr/sbin
  /usr/bin
  /sbin
  /bin
  $path
)

# OS Specific Paths
case ${OSTYPE} in
  darwin*)
    alias emacs="TERM=xterm-256color /usr/local/bin/emacs"
    ;;
  linux*)
    # Default Homebrew Location for Linux
    if [[ -d /home/linuxbrew/.linuxbrew ]]; then
      eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
      fpath=(/home/linuxbrew/.linuxbrew/share/zsh-completions $fpath)
    # Legacy Linuxbrew Location
    elif [[ -d $HOME/.linuxbrew ]]; then
      export BREW_DIR=$HOME/.linuxbrew
      path=($BREW_DIR/bin $path)
      manpath=($BREW_DIR/share/man $manpath)
      infopath=($BREW_DIR/share/info $infopath)
      fpath=($BREW_DIR/share/zsh-completions $fpath)
    fi
    ;;
esac

# Go settings (mise manages go binaries, but GOPRIVATE is still needed)
export GOPRIVATE="github.com/tier4"

# ==============================================================================
# 2. Frameworks & Toolchains (Prezto, Mise)
# ==============================================================================
# Start Prezto
if [[ -s "${ZDOTDIR:-$HOME}/.zprezto/init.zsh" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprezto/init.zsh"
fi

# Activate Mise
if command -v mise > /dev/null; then
  eval "$(mise activate zsh)"
fi

# ==============================================================================
# 3. Zsh Options & History
# ==============================================================================
HISTFILE=${XDG_DATA_HOME:-$HOME/.local/share}/zsh/zsh_history
HISTSIZE=1000000
SAVEHIST=1000000
DIRSTACKSIZE=100

setopt auto_cd              # cd automatically without 'cd'
setopt auto_pushd           # Make cd push the old directory onto the directory stack
setopt pushd_ignore_dups    # Don't push multiple copies of the same directory
setopt interactive_comments # Allow comments starting with #
setopt print_eight_bit      # Display japanese characters correctly
setopt magic_equal_subst    # Perform filename expansion after =
setopt extended_glob        # Treat #, ~, and ^ as part of patterns for filename generation
setopt nonomatch            # If a pattern has no matches, treat it as a string instead of an error
setopt no_beep              # Disable beeping
setopt no_flow_control      # Disable start/stop characters (ctrl-s/ctrl-q)

# History options
setopt share_history          # Share history between all sessions
setopt hist_ignore_all_dups   # Delete old recorded entry if new entry is a duplicate
setopt hist_save_nodups       # Don't write duplicate entries in the history file
setopt hist_ignore_space      # Don't record an entry starting with a space
setopt hist_reduce_blanks     # Remove superfluous blanks before recording entry

# Key bindings
bindkey -e                    # Emacs mode
bindkey '^R' history-incremental-pattern-search-backward # Pattern search backward

# ==============================================================================
# 4. Completion System
# ==============================================================================
# Load compinit once
autoload -Uz compinit
compinit -u

# Configure completions
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' # Case-insensitive matching
zstyle ':completion:*' ignore-parents parent pwd .. # Ignore parent dir in ../
zstyle ':completion:*' menu select=1                # Tab selection menu
zstyle ':completion:*:cd:*' ignore-parents parent pwd
zstyle ':completion:*:descriptions' format '%BCompleting%b %U%d%u'
zstyle ':completion:*:processes' command 'ps x -o pid,s,args' # ps processes match
zstyle ':completion:*:sudo:*' command-path /usr/local/sbin /usr/local/bin /usr/sbin /usr/bin /sbin /bin /usr/X11R6/bin

# Word separators
autoload -Uz select-word-style
select-word-style default
zstyle ':zle:*' word-chars " /=;@:{},|"
zstyle ':zle:*' word-style unspecified

# ==============================================================================
# 5. Aliases & Global Aliases
# ==============================================================================
alias ll='ls -l'
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias mkdir='mkdir -p'
alias ...='cd ../..'
alias ....='cd ../../..'
alias grep='grep --color'
alias sudo='nocorrect sudo '

alias -g emacs='emacsclient -nw -a ""'
alias -g e='emacs'

# Global Aliases (Piping)
alias -g L='| less'
alias -g G='| grep'
alias -g P='| peco'

# Clipboard piping depending on OS
if which pbcopy >/dev/null 2>&1 ; then
  alias -g C='| pbcopy'      # Mac
elif which xsel >/dev/null 2>&1 ; then
  alias -g C='| xsel --input --clipboard'  # Linux
elif which putclip >/dev/null 2>&1 ; then
  alias -g C='| putclip'     # Cygwin
fi

# ==============================================================================
# 6. Integrations (Peco, PIPENV, AWS, 1Password)
# ==============================================================================

# -- Peco Functions --
if command -v peco > /dev/null; then
  # History Search
  function peco-select-history() {
    local tac_cmd="tac"
    if ! command -v tac >/dev/null; then tac_cmd="tail -r"; fi
    BUFFER=$(\history -n 1 | eval $tac_cmd | peco --query "$LBUFFER")
    CURSOR=$#BUFFER
    zle clear-screen
  }
  zle -N peco-select-history
  bindkey '^r' peco-select-history

  # CDR (Recent Directories) Search
  function peco-get-destination-from-cdr() {
    cdr -l | sed -e 's/^[[:digit:]]*[[:blank:]]*//' | peco --query "$LBUFFER"
  }
  function peco-cdr() {
    local destination="$(peco-get-destination-from-cdr)"
    if [ -n "$destination" ]; then
      BUFFER="cd $destination"
      zle accept-line
    else
      zle reset-prompt
    fi
  }
  zle -N peco-cdr
  bindkey '^x' peco-cdr

  # Process Kill (Usage: pk)
  function peco-pkill() {
    for pid in $(ps aux | peco | awk '{ print $2 }'); do
      kill $pid && echo "Killed ${pid}"
    done
  }
  alias pk="peco-pkill"
fi

# -- Pipenv --
if command -v pipenv > /dev/null; then
  eval "$(_PIPENV_COMPLETE=zsh_source pipenv)"
fi

# -- 1Password --
if [[ -e "$HOME/.config/op/plugins.sh" ]]; then
  source "$HOME/.config/op/plugins.sh"
fi

# -- AWS Vault --
if command -v aws-vault > /dev/null; then
  eval "$(aws-vault --completion-script-zsh)"
  alias av='aws-vault'
  alias ave='aws-vault exec'
  alias avl='aws-vault login'
fi

# ==============================================================================
# 7. Local Secrets & Theme Generation 
# ==============================================================================
# Source local secrets if existing
if [[ -f ${XDG_CONFIG_HOME:-$HOME/.config}/zsh/.secret ]]; then
  source ${XDG_CONFIG_HOME:-$HOME/.config}/zsh/.secret
elif [[ -f ~/.secret ]]; then
  source ~/.secret
fi

# Load Powerlevel10k theme configuration at the very end
[[ ! -f ${ZDOTDIR:-$HOME}/.p10k.zsh ]] || source ${ZDOTDIR:-$HOME}/.p10k.zsh
